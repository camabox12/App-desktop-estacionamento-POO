        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n    class Veiculo {\n        &lt;&lt;abstract&gt;&gt;\n        -String __placa\n        +placa() String\n        +calcular_tarifa_base()* Float\n        +tipo()* String\n    }\n\n    class Carro {\n        +calcular_tarifa_base() Float\n        +tipo() String\n    }\n\n    class Moto {\n        +calcular_tarifa_base() Float\n        +tipo() String\n    }\n\n    class Ticket {\n        -Integer __id_ticket\n        -Veiculo __veiculo\n        -DateTime __hora_entrada\n        -Tarifa __tarifa\n        +id_ticket() Integer\n        +veiculo() Veiculo\n        +hora_entrada() DateTime\n        +calcular_valor_atual() Tuple\n        +fechar_ticket() Tuple\n    }\n\n    class Tarifa {\n        -Float __valor_total\n        +valor_total() Float\n    }\n\n    class SistemaEstacionamento {\n        -Dictionary __vagas_ocupadas\n        -Float __faturamento_total\n        -Integer __contador_id\n        +vagas_ocupadas() Dictionary\n        +faturamento_total() Float\n        +registrar_entrada(placa, tipo)\n        +registrar_saida(placa)\n        +monitorar_patio()\n    }\n\n    Veiculo &lt;|-- Carro : Herança\n    Veiculo &lt;|-- Moto : Herança\n    Ticket --&gt; Veiculo : Associação (1)\n    Ticket *-- Tarifa : Composição (1)\n    SistemaEstacionamento --&gt; Ticket : Gerencia (N)&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="JRpT-O_asA1uNFvgnOV2-1">
